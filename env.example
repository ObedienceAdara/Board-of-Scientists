# ── LLM via Groq ─────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Web Search ─────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here

# ── LangSmith ──────────────────────────────────────────────────
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=AIResearchTeam

# ── Model Overrides (optional) ─────────────────────────────────
# Defaults to google/gemini-2.0-flash-exp:free (free tier) for all agents.
# For best results on real papers, use paid models:
#
# CRO_MODEL=anthropic/claude-3.5-sonnet         ← Best for synthesis & evaluation
# ANALYST_MODEL=google/gemini-2.0-flash-001     ← Best for long document reading
# THEORIST_MODEL=deepseek/deepseek-r1           ← Best for mathematical reasoning
# ARCHITECT_MODEL=deepseek/deepseek-r1          ← Best for systems design
# ENGINEER_MODEL=anthropic/claude-3.5-sonnet    ← Best for code generation
# REVIEWER_MODEL=anthropic/claude-3.5-sonnet    ← Best for code review
# EXPERIMENT_MODEL=google/gemini-2.0-flash-001  ← Fast, good for validation
# WRITER_MODEL=anthropic/claude-3.5-haiku       ← Good for documentation
